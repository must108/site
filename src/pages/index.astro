---
import "../styles/global.css";
import { Icon } from "astro-icon/components";
import SEO from "../components/SEO.astro";
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-icon.jpg" />
    <meta name="theme-color" content="#09090B" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} />
  </head>
  <body
    class="bg-[#102A43] text-[#EAF4FF] min-h-screen flex items-center justify-center"
  >
    <div class="max-w-2xl mx-auto pt-5 sm:pt-15 p-10 flex flex-col">
      <p class="text-3xl sm:text-6xl pb-2">mustaeen ahmed</p>
      <div>
        <p class="text-md sm:text-lg font-semibold">current</p>
        <ul class="text-sm sm:text-lg pl-5 pb-5 list-disc">
          <li>working at <b>?</b></li>
          <li>
            <div class="flex flex-wrap items-center gap-y-1 sm:gap-x-1">
              <span class="shrink-0 whitespace-nowrap mr-1"
                >contributing to</span
              >

              <a
                href="https://prometheus.io/"
                target="_blank"
                aria-label="Prometheus"
                class="w-8 h-8 inline-flex items-center justify-center"
                title="Prometheus"
              >
                <Icon name="logos/prometheus" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
              </a>
              <a
                href="https://opentelemetry.io/"
                target="_blank"
                aria-label="OpenTelemetry"
                class="w-8 h-8 inline-flex items-center justify-center"
                title="OpenTelemetry"
              >
                <Icon name="logos/opentelemetry" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
              </a>
              <a
                href="https://clickhouse.com/"
                target="_blank"
                aria-label="ClickHouse"
                class="w-8 h-8 inline-flex items-center justify-center"
                title="ClickHouse"
              >
                <Icon name="logos/clickhouse" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
              </a>
            </div>
          </li>
          <li>
            <div class="inline-flex items-center gap-1">
              studying at
              <a href="https://www.ucf.edu/" target="_blank" aria-label="UCF">
                <Icon
                  name="logos/ucf"
                  class="w-8 h-8 inline-flex items-center justify-center text-black"
                  title="UCF"
                />
              </a>
            </div>
          </li>
        </ul>
      </div>
      <p class="text-md sm:text-lg font-semibold">previous</p>
      <ul class="text-sm sm:text-lg pl-5 pb-5 list-disc">
        <li>
          <div class="inline-flex flex-wrap items-center sm:gap-x-1">
            <a
              href="https://www.cloudflare.com/"
              target="_blank"
              aria-label="Cloudflare"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="Cloudflare"
            >
              <Icon name="logos/cloudflare" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://joinhandshake.com/"
              target="_blank"
              aria-label="Handshake"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="Handshake"
            >
              <Icon name="logos/handshake" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://www.morganstanley.com/"
              target="_blank"
              aria-label="Morgan Stanley"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="Morgan Stanley"
            >
              <Icon name="logos/morganstanley" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://8vc.com/"
              target="_blank"
              aria-label="Ideaflow (8VC)"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="8VC"
            >
              <Icon name="logos/8vc" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://www.leidos.com/"
              target="_blank"
              aria-label="Leidos"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="Leidos"
            >
              <Icon name="logos/leidos" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://www.cae.com/"
              target="_blank"
              aria-label="CAE"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="CAE"
            >
              <Icon name="logos/cae" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
            <a
              href="https://www.darden.com/"
              target="_blank"
              aria-label="Darden"
              class="w-8 h-8 inline-flex items-center justify-center"
              title="Darden"
            >
              <Icon name="logos/darden" class="block w-[24px] h-[24px] sm:w-[30px] sm:h-[30px]" />
            </a>
          </div>
        </li>
        <li>... among others!</li>
      </ul>
      <div>
        <div class="text-sm text-[#EAF4FF] flex flex-row gap-4 pb-5">
          <a
            href="/resume.pdf"
            target="_blank"
            class="hover:text-[#A7DBFF] inline-flex items-center justify-center"
          >
            <Icon
              name="logos/resume"
              class="w-6 h-6 inline-flex items-center justify-center block"
              aria-label="Resume"
              title="Resume"
            />
          </a>
          <a
            href="https://github.com/must108"
            target="_blank"
            class="hover:text-[#A7DBFF] inline-flex items-center justify-center"
          >
            <Icon
              name="logos/github_dark"
              class="w-6 h-6 inline-flex items-center justify-center block"
              aria-label="GitHub"
              title="GitHub"
            />
          </a>
          <a
            href="https://www.linkedin.com/in/mustaeenahmed/"
            target="_blank"
            class="hover:text-[#A7DBFF] inline-flex items-center justify-center"
          >
            <Icon
              name="logos/linkedin"
              class="w-6 h-6 inline-flex items-center justify-center block"
              aria-label="LinkedIn"
              title="LinkedIn"
            />
          </a>
          <a
            href="mailto:contact@mustaeen.dev"
            target="_blank"
            class="hover:text-[#A7DBFF] inline-flex items-center justify-center"
          >
            <Icon
              name="logos/mail"
              class="w-[30px] h-[30px] inline-flex items-center justify-center block"
              aria-label="Email"
              title="Email"
            />
          </a>
        </div>
      </div>
    </div>
  </body>
</html>
